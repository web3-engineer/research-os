// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- MODELO DE USUÁRIO ---
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?   
  
  // Profile
  course        String?   
  bio           String?   
  age           Int?
  gender        String?
  torsoImage    String?   
  role          String?   
  phone         String?   
  
  // Gamification
  level         Int       @default(1)
  streak        Int       @default(0)
  xp            Int       @default(0)
  
  // Identity
  identityId    String?   
  idType        String?   
  walletAddress String?   
  
  // Admin
  kycStatus     String    @default("pending")
  documents     Json?     
  institution   String?   

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  comments      Comment[]
  userSpaceData UserSpaceData?
}

// --- MEMÓRIA DO LOUNGE & SALAS ---
model UserSpaceData {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Base UI
  layout        Json?    // Armazena janelas abertas e posições
  settings      Json?    // Armazena tema e preferências
  
  // State Persistence
  layoutState     Json?    
  schedule        Json?    
  stickyNote      String?  
  
  // Modules & History
  chatHistory     Json?    
  zaeonChat       Json?    
  library         Json?    
  fabricator      Json?    
  personalModules Json?    

  // Profile & Objectives
  objectives      Json?    

  // Legacy/Work
  activeProject   Json?    
  citations       Json?    
  workContent     String?  
  workTitle       String?  

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt 
}

model SystemSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique 
  value     String   
  updatedAt DateTime @updatedAt
}

// --- MODELO POST ATUALIZADO (NEURAL EDITOR) ---
model Post {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String?
  subtitle    String?
  content     String
  tags        String[] @default([])
  images      String[] @default([]) // Máximo 5 pelo front
  attachments Json?    // Links ou Docs
  likes       String[] @default([]) 
  createdAt   DateTime @default(now())
  room        String   @default("cyber") 
  user        String   
  userImage   String?  
  userId      String?  @db.ObjectId
  author      User?    @relation(fields: [userId], references: [id])
  comments    Comment[]
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  user      String   
  createdAt DateTime @default(now())
  postId    String   @db.ObjectId
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String?  @db.ObjectId
  author    User?    @relation(fields: [userId], references: [id])
}

model NewsPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       Json
  subtitle    Json?
  content     Json
  imageUrl    String?
  publishDate DateTime @default(now())
  status      String   @default("draft")
  category    String   @default("news") 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- NOVO MODELO DE PLUGINS (GAMIFIED STORE) ---
model Plugin {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  author            String   @default("Zaeon Core")
  description       String
  category          String   // Essencial, Agentes, Mentorias, Blockchain
  tag               String?  // Livre, Alunos, VIP
  price             Float    @default(0)
  actionUrl         String
  isLocked          Boolean  @default(false)
  unlockRequirement String?  // Ex: "Nível 5 necessário"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.String
  access_token       String? @db.String
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.String
  session_state      String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  action    String   
  details   String?
  createdAt DateTime @default(now())
}