// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- MODELO DE USUÁRIO ---
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?   
  
  // Profile
  course        String?   
  bio           String?   
  age           Int?
  gender        String?
  torsoImage    String?   
  role          String?   
  phone         String?   

  // Status de Presença
  isOnline       Boolean   @default(false)
  
  // Gamification
  level         Int       @default(1)
  streak        Int       @default(0)
  xp            Int       @default(0)
  
  // Identity
  identityId    String?   
  idType        String?   
  walletAddress String?   
  
  // Admin
  kycStatus     String    @default("pending")
  documents     Json?     
  institution   String?   

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  comments      Comment[]
  userSpaceData UserSpaceData?
  automationFlows AutomationFlow[] // Conexão com Tarefa 2
}

// --- MEMÓRIA DO LOUNGE & SALAS ---
model UserSpaceData {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Base UI
  layout    Json?    
  settings  Json?    
  
  // State Persistence
  layoutState     Json?    
  schedule        Json?    
  stickyNote      String?  
  
  // Modules & History
  chatHistory     Json?    
  zaeonChat       Json?    
  library         Json?    
  fabricator      Json?    
  personalModules Json?    

  // Profile & Objectives
  objectives      Json?    

  // Legacy/Work
  activeProject   Json?    
  citations       Json?    
  workContent     String?  
  workTitle       String?  

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt 
}

model SystemSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique 
  value     String   
  updatedAt DateTime @updatedAt
}

model Room {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  slug         String   @unique 
  name         String
  description  String?
  isPrivate    Boolean  @default(false)
  allowedUsers String[] @db.ObjectId 
  ownerId      String   @db.ObjectId // Garante que o ID do dono seja um ObjectId
  createdAt    DateTime @default(now())
  posts        Post[]   
}

model Post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  likes     String[] @default([]) 
  createdAt DateTime @default(now())
  
  // Relacionamento com a Sala (Obrigatório)
  roomId    String   @db.ObjectId
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  // Relacionamento com o Usuário (Autor)
  userId    String   @db.ObjectId // Tornamos obrigatório para evitar posts "órfãos"
  author    User     @relation(fields: [userId], references: [id])
  
  // Campos redundantes para performance 
  user      String   
  userImage String?  
  
  comments  Comment[]
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  user      String   
  createdAt DateTime @default(now())
  postId    String   @db.ObjectId
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String?  @db.ObjectId
  author    User?    @relation(fields: [userId], references: [id])
}

model NewsPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       Json
  subtitle    Json?
  content     Json
  imageUrl    String?
  publishDate DateTime @default(now())
  status      String   @default("draft")
  category    String   @default("news") 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  action    String   
  details   String?
  createdAt DateTime @default(now())
}

model AutomationFlow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   
  trigger     String   
  condition   Json?    
  action      String   
  actionData  Json?    
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ModuleCatalog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique 
  description String
  version     String
  configSchema Json?    
  icon        String?
  isPremium   Boolean  @default(false)
}